{
  "name": "visitor-counter",
  "version": "1.0.0",
  "private": true,
  "description": "Privacy-respecting visitor counter for indulohithnarisetty.com — Cloudflare Worker + KV.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "kv:create": "wrangler kv namespace create VISITOR_COUNTER",
    "kv:seed": "wrangler kv key put --binding=COUNTER total 0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241022.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.84.0"
  }
}
